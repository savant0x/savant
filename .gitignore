# Agent runtime state — not source code
dev/session-summaries/*
dev/fids/*
!dev/fids/.gitkeep
!dev/fids/archive/
!dev/fids/archive/.gitkeep
!.gitkeep

# Keep LEARNINGS.md tracked — cross-session knowledge
!dev/LEARNINGS.md

# Heavy reference material + research notes — gitignored, not shipped
resources/
prompts/

# Firebase
firebase-debug.log
.firebaserc
firebase.json

# OS
.DS_Store
Thumbs.db

# Rust / Cargo
target/
release/
debug/
*.rs.bk
.fingerprint/
.cargo/

# Tauri 2
src-tauri/target/
src-tauri/gen/schemas/

# Node / Vite / Renderer — NOT Next.js (explicitly forbidden in ECHO Phase 1)
node_modules/
dist/
out/
build/
.vite/
*.tsbuildinfo
.eslintcache
.next/
.turbo/
.parcel-cache/

# Local environment — NEVER commit secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Database — Phase 2+ SQLite WAL artifacts
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# Logs / runtime output
logs/
*.log
*.tmp

# Editor / OS / Dev environment
.vscode/
.idea/
.cursor/
