*.swo

# Local agent hotlink files (runtime, not source)
.vera
.savant
AGENTS.md  # ignored at root if accidentally created by auto-tools; project ECHO.md is authoritative

# Vault secrets — NEVER commit (defense in depth)
auth.json
vault.json
master_key.json
*.mkey

# npm runtime cache
.npm

# Local Rust build cache
.cargo/
