    "prettier": "^3.5.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0",
    "vite-tsconfig-paths": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22"
