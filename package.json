{
  "name": "savant",
  "description": "Savant AI desktop shell (Renderer-first rebuild, Rust core pending)",
  "license": "Apache-2.0",
  "private": true,
  "version": "0.0.8",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:all": "npm run test && npm run test:e2e",
    "lint:docs": "bash scripts/lint-docs.sh",
    "lint:defer": "bash scripts/lint-defer.sh",
    "lint:ci": "pnpm lint && pnpm lint:docs && pnpm lint:defer",
    "release:check": "bash scripts/release-check.sh",
    "release:prep": "bash scripts/release-prep.sh",
    "release:archive": "bash scripts/archive-fids.sh",
    "release:bump": "bash scripts/bump-version.sh",
    "release:readme": "bash scripts/refresh-readme.sh",
    "release:clean": "bash scripts/clean-bloat.sh",
    "git:commit": "bash scripts/commit-with-message.sh",
    "git:tag": "bash scripts/tag-with-message.sh",
    "verify:fix": "bash scripts/verify-fix.sh"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@heroui/react": "alpha",
    "@heroui/styles": "alpha",
    "@tauri-apps/api": "^2.4.0",
    "motion": "^12.42.2",
    "next": "^15.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "happy-dom": "^15.11.0",
    "prettier": "^3.5.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=22"
  }
}
